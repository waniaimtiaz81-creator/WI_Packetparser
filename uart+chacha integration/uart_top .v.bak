uart_top.v (The Controller)
Isme maine loopback khatam kar diya hai aur ek 64-byte buffer daal diya hai jo UART aur ChaCha ko aapas mein jorta hai.



module uart_top (
    input  wire        clk,
    input  wire        raw_reset,
    input  wire        rx,
    output wire        tx
);

    wire        tick;
    wire        reset;
    wire [7:0]  rx_data_out;
    wire        rx_data_ready;
    wire [511:0] chacha_data_out;
    wire        chacha_ready;
    wire        chacha_data_out_valid;
    
    reg [511:0] chacha_data_in;
    reg [5:0]   byte_count;
    reg         chacha_init;
    reg         tx_start;
    reg [7:0]   tx_data_in;
    reg [2:0]   master_state;
    reg [5:0]   tx_byte_count;

    assign reset = ~raw_reset;

    // FSM States for Integration
    localparam S_IDLE       = 3'd0;
    localparam S_COLLECT    = 3'd1;
    localparam S_ENCRYPT    = 3'd2;
    localparam S_TRANSMIT   = 3'd3;
    localparam S_WAIT_TX    = 3'd4;

    // --- Master Control Logic (Handshaking) ---
    always @(posedge clk or posedge reset) begin
        if (reset) begin
            byte_count <= 0;
            chacha_init <= 0;
            master_state <= S_IDLE;
            tx_start <= 0;
            tx_byte_count <= 0;
            chacha_data_in <= 0;
        end else begin
            case (master_state)
                S_IDLE: begin
                    byte_count <= 0;
                    master_state <= S_COLLECT;
                end

                S_COLLECT: begin
                    if (rx_data_ready) begin
                        // Store byte into 512-bit register (Big Endian format)
                        chacha_data_in <= {chacha_data_in[503:0], rx_data_out};
                        if (byte_count == 63) begin
                            chacha_init <= 1;
                            master_state <= S_ENCRYPT;
                        end else begin
                            byte_count <= byte_count + 1;
                        end
                    end
                end

                S_ENCRYPT: begin
                    chacha_init <= 0;
                    if (chacha_data_out_valid) begin
                        master_state <= S_TRANSMIT;
                        tx_byte_count <= 0;
                    end
                end

                S_TRANSMIT: begin
                    if (!tx_busy) begin
                        // Extract 1 byte from 512-bit encrypted data
                        tx_data_in <= chacha_data_out[(63-tx_byte_count)*8 +: 8];
                        tx_start <= 1;
                        master_state <= S_WAIT_TX;
                    end
                end

                S_WAIT_TX: begin
                    tx_start <= 0;
                    if (tx_done) begin
                        if (tx_byte_count == 63)
                            master_state <= S_IDLE;
                        else begin
                            tx_byte_count <= tx_byte_count + 1;
                            master_state <= S_TRANSMIT;
                        end
                    end
                end
            endcase
        end
    end

    // UART Modules & ChaCha Instantiation
    baud_gen #(.BAUD_DIV(5208)) baud_inst (.clk(clk), .reset(reset), .tick(tick));

    uart_rx rx_inst (
        .clk(clk), .reset(reset), .tick(tick), .rx(rx),
        .data_out(rx_data_out), .data_ready(rx_data_ready), .busy()
    );

    wire tx_busy, tx_done;
    uart_tx tx_inst (
        .clk(clk), .reset(reset), .tick(tick), .start(tx_start),
        .data_in(tx_data_in), .tx(tx), .busy(tx_busy), .done(tx_done)
    );

    // Connecting ChaCha Core directly to bypass address-based complexity for now
    chacha_core chacha_inst (
        .clk(clk), .reset_n(~reset), .init(chacha_init), .next(1'b0),
        .key(256'h03020100070605040b0a09080f0e0d0c13121110171615141b1a19181f1e1d1c), // Fixed Key
        .keylen(1'b1), .iv(64'h0000000000000009), .ctr(64'h0), .rounds(5'd20),
        .data_in(chacha_data_in), .ready(chacha_ready),
        .data_out(chacha_data_out), .data_out_valid(chacha_data_out_valid)
    );

endmodule